  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--port", "5000"],
      "jinja": false
    },
    {
      "name": "Autopilot: Fetch Jobs",
      "type": "debugpy",
      "request": "launch",
      "module": "app.cli",
      "args": ["fetch"]
    },
    {
      "name": "Autopilot: Score Jobs",
      "type": "debugpy",
      "request": "launch",
      "module": "app.cli",
      "args": ["score"]
    },
    {
      "name": "Autopilot: Taylor Resumes",
      "type": "debugpy",
      "request": "launch",
      "module": "app.cli",
      "args": ["taylor"]
    },
    {
      "name": "Autopilot: Apply Jobs",
      "type": "debugpy",
      "request": "launch",
      "module": "app.cli",
      "args": ["apply"]
    }
  ]
}
